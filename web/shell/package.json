{
  "name": "@dbgpt/shell",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "DB-GPT new Vite + React Router shell (strangler migration target). See adr/0001-unify-frontend-stack.md.",
  "scripts": {
    "dev": "react-router dev",
    "build": "NODE_OPTIONS=--max_old_space_size=8192 react-router build",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint app --max-warnings=0",
    "lint:fix": "eslint app --fix",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ant-design/icons": "^5.6.0",
    "@dbgpt/shared": "workspace:*",
    "@microsoft/fetch-event-source": "^2.0.1",
    "@tanstack/react-query": "^5.50.0",
    "ahooks": "^3.8.0",
    "antd": "^5.10.0",
    "axios": "^1.7.0",
    "dayjs": "^1.11.12",
    "i18next": "^23.12.0",
    "lodash": "^4.17.21",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^14.1.0",
    "react-router": "^7.0.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@react-router/dev": "^7.0.0",
    "@react-router/node": "^7.0.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.2.14",
    "@types/react-dom": "^18.2.6",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/ui": "^2.0.0",
    "autoprefixer": "^10.4.14",
    "eslint": "^9.0.0",
    "jsdom": "^24.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "tailwindcss-animated": "^1.0.1",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^7.0.0",
    "vite-tsconfig-paths": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
