    "format": "prettier --write '**/*.{ts,tsx}'",
    "typecheck": "bash scripts/typecheck-check.sh",
    "typecheck:raw": "tsc --noEmit",
    "typecheck:baseline": "tsc --noEmit 2>&1 | grep 'error TS' | sort > .typecheck-baseline.txt",
