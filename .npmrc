# pnpm hoist rules.
# React Router's vite plugin resolves @react-router/node from its own location;
# pnpm's strict node_modules hides it. Public-hoist the React Router and
# TanStack packages so the plugin's require.resolve succeeds.
# See adr/0001-unify-frontend-stack.md.
public-hoist-pattern[]=@react-router/*
public-hoist-pattern[]=@tanstack/*
